# Stripe test key initially; never commit the real value
STRIPE_SECRET_KEY=sk_test_replace_me

# Created after configuring the Stripe webhook
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Long random token used to access /admin.html
IZHE_ADMIN_TOKEN=replace_with_a_long_random_secret

# Shipping charge in cents: 695 = $6.95
IZHE_SHIPPING_CENTS=695

# Netlify URL or final custom domain, without a trailing slash
SITE_URL=https://your-site-name.netlify.app
